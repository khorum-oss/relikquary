.kotlin/
**/node_modules/
frontend/.svelte-kit/
.git/
.github/
.idea/
.vscode/
relikquary-store*/
**/.env
deploy/.env
*.asc
*.gpg
secret.properties
**/http-client.private.env.json
specs/
.specify/

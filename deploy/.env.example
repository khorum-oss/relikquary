# Copy to deploy/.env and fill in real values. deploy/.env is git-ignored — never commit real secrets.
# Used by deploy/docker-compose.yml.

# --- Publisher (required; auth is ON by default) ---
# A user with the PUBLISH role. The password MUST carry an encoder prefix: {noop}<plain> for quick
# starts, or {bcrypt}<hash> for real deployments. Replace the value below before exposing the server.
RELIKQUARY_PUBLISHER_USER=publisher
RELIKQUARY_PUBLISHER_PASSWORD={noop}changeme

# --- Application state (tokens / users / settings / publish history) ---
# Default is embedded SQLite (persisted on its own volume) — nothing to set. To store application state
# in PostgreSQL, layer deploy/docker-compose.postgres.yml and set the database password below (the
# name/user default to "relikquary"). This is separate from artifact storage above.
# RELIKQUARY_DB_NAME=relikquary
# RELIKQUARY_DB_USER=relikquary
RELIKQUARY_DB_PASSWORD=changeme

# --- Storage backend (default: filesystem on a persistent volume) ---
# To use S3-compatible object storage instead, set backend=s3 and fill the S3 settings below, then
# remove/ignore the filesystem volume in docker-compose.yml. (See the commented S3 block there.)
# RELIKQUARY_STORAGE_BACKEND=s3
# RELIKQUARY_S3_ENDPOINT=https://s3.example.com
# RELIKQUARY_S3_REGION=us-east-1
# RELIKQUARY_S3_BUCKET=relikquary
# RELIKQUARY_S3_ACCESS_KEY=changeme
# RELIKQUARY_S3_SECRET_KEY=changeme

# --- Optional upstream overrides (default to public Maven Central / Gradle Plugin Portal) ---
# RELIKQUARY_MAVEN_CENTRAL_URL=https://repo1.maven.org/maven2
# RELIKQUARY_GRADLE_PLUGIN_PORTAL_URL=https://plugins.gradle.org/m2/
